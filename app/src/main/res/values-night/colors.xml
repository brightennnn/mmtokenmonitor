<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Widget 背景色 - 深色模式不透明 -->
    <color name="widget_background">#FF1C1B1F</color>

    <!-- Widget 进度条填充色 -->
    <color name="widget_progress_fill">#FFCFBCFF</color>

    <!-- Widget 文字颜色 - 深色模式 -->
    <color name="widget_text_primary">#FFFFFFFF</color>
    <color name="widget_text_secondary">#B3FFFFFF</color>

    <!-- Widget 文字颜色（跟随系统明暗，Kotlin 动态覆盖用） -->
    <color name="widget_color_on_surface">#FFFFFFFF</color>
    <color name="widget_color_on_surface_variant">#B3FFFFFF</color>

    <!-- Launcher Icon - 深色模式 -->
    <color name="primaryBackground">@android:color/system_accent2_800</color>
    <color name="primaryForeground">@android:color/system_accent1_200</color>
</resources>
