<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MiniMaxTokenApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MiniMaxToken">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MiniMaxToken">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 5小时用量 Widget — Glance 1.2 -->
        <receiver
            android:name=".widget.GlanceIntervalWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_interval_widget_info" />
        </receiver>

        <!-- 本周用量 Widget — Glance 1.2 -->
        <receiver
            android:name=".widget.GlanceWeeklyWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/glance_weekly_widget_info" />
        </receiver>

        <!-- 壁纸变化监听器 -->
        <receiver
            android:name=".widget.WallpaperChangedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.WALLPAPER_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Widget 定时刷新 -->
        <receiver
            android:name=".widget.WidgetAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="io.github.brightennnn.mmtokenmonitor.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <intent-filter>
                <action android:name="io.github.brightennnn.mmtokenmonitor.ACTION_CLICK_REFRESH" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for widget wave images -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.widgetwaves"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/widget_waves_paths" />
        </provider>
    </application>

</manifest>
